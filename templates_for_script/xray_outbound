{
  "tag": "default",
  "protocol": "vless",
  "settings": {
    "vnext": [
      {
        "address": "$VLESS_DOMAIN",
        "port": $XRAY_PORT,
        "users": [
          {
            "id": "$XRAY_UUID",
            "encryption": "none"
          }
        ]
      }
    ]
  },
  "streamSettings": {
    "network": "grpc",
    "security": "reality",
    "grpcSettings": {
      "serviceName": "api.v1.telemetry.EventStream",
      "multiMode": false
    },
    "realitySettings": {
      "serverName": "$VLESS_DOMAIN",
      "fingerprint": "firefox",
      "publicKey": "$XRAY_PBK",
      "shortId": "$XRAY_SID",
      "spiderX": ""
    }
  }
}
