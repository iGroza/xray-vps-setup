{
    "type": "vless",
    "server": "$VLESS_DOMAIN",
    "server_port": $XRAY_PORT,
    "uuid": "$XRAY_UUID",
    "tls": {
        "enabled": true,
        "insecure": false,
        "server_name": "$VLESS_DOMAIN",
        "utls": {
            "enabled": true,
            "fingerprint": "firefox"
        },
        "reality": {
            "enabled": true,
            "public_key": "$XRAY_PBK",
            "short_id": "$XRAY_SID"
        }
    },
    "transport": {
        "type": "grpc",
        "service_name": "api.v1.telemetry.EventStream"
    }
}
